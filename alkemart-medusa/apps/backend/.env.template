# -----------------------------------------------------------------------------
# Medusa / Alkemart backend environment
# Copy to `.env` and fill in real values. Never commit `.env`.
# Validated at boot by src/lib/env.ts (Zod). Production refuses default secrets.
# -----------------------------------------------------------------------------

# Runtime mode: development | test | production (default: development)
NODE_ENV=development

# Postgres connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/medusa-backend

# Redis (required; used by Medusa workers/cache when configured)
REDIS_URL=redis://localhost:6379

# Auth secrets
# Development: min 8 characters (local may use temporary values).
# Production: min 32 characters and must NOT be "supersecret" / similar defaults.
JWT_SECRET=change-me-min-32-chars-jwt-secret-here
COOKIE_SECRET=change-me-min-32-chars-cookie-secret

# CORS allow-lists (comma-separated origins, required)
STORE_CORS=http://localhost:8000,http://localhost:5173
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000

# -----------------------------------------------------------------------------
# Alkemart marketplace seed / storefront wiring (optional in development)
# Required in production: ALKEMART_REGION_ID, ALKEMART_SALES_CHANNEL_ID
# -----------------------------------------------------------------------------
ALKEMART_REGION_ID=
ALKEMART_SALES_CHANNEL_ID=
ALKEMART_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Paystack (optional in development; PAYSTACK_SECRET_KEY required in production)
# Do not register the Paystack module until a later phase — keys are validated only.
# -----------------------------------------------------------------------------
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# Commerce defaults
# -----------------------------------------------------------------------------
# ISO currency code used for storefront defaults (default: ghs)
DEFAULT_CURRENCY=ghs
# ISO country code (default: gh)
DEFAULT_COUNTRY_CODE=gh
# Pending payment intent TTL in minutes (default 30, allowed 10–120)
PAYMENT_PENDING_TTL_MINUTES=30
# Platform commission in basis points (default 700 = 7.00%)
DEFAULT_COMMISSION_BPS=700
