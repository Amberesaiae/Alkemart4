# -----------------------------------------------------------------------------
# Medusa / Alkemart backend environment
# Copy to `.env` and fill in real values. Never commit `.env`.
# Validated at boot by src/lib/env.ts (Zod). Production refuses default secrets.
#
# Neon layout: docs/architecture/2026-07-15-neon-database-layout.md
# -----------------------------------------------------------------------------

# Runtime mode: development | test | production (default: development)
NODE_ENV=development

# -----------------------------------------------------------------------------
# Neon / Postgres
# -----------------------------------------------------------------------------
# DATABASE_URL = Medusa's Neon connection (runtime). Prefer Neon POOLED host
# (-pooler in hostname). Target DB name/branch: alkemart_medusa (ADR-P1).
# Today may still point at shared neondb during transitional migration only.
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/alkemart_medusa?sslmode=require

# EXPRESS_DATABASE_URL = Express Drizzle source for ETL (migrate-from-express) ONLY.
# Never used by Medusa store/admin/worker runtime. Leave empty if not running ETL.
EXPRESS_DATABASE_URL=

# ALLOW_EXPRESS_MIGRATE = production safety gate for ETL scripts under
# src/scripts/migrate-from-express/. Required "true" when NODE_ENV=production.
# Leave unset / false outside deliberate migration windows.
ALLOW_EXPRESS_MIGRATE=

# Redis (required; used by Medusa workers/cache when configured)
REDIS_URL=redis://localhost:6379

# Auth secrets
# Development: min 8 characters (local may use temporary values).
# Production: min 32 characters and must NOT be "supersecret" / similar defaults.
JWT_SECRET=change-me-min-32-chars-jwt-secret-here
COOKIE_SECRET=change-me-min-32-chars-cookie-secret

# CORS allow-lists (comma-separated origins, required)
STORE_CORS=http://localhost:8000,http://localhost:5173
ADMIN_CORS=http://localhost:5173,http://localhost:9000
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000

# -----------------------------------------------------------------------------
# Alkemart marketplace / storefront wiring
# Required in production: ALKEMART_REGION_ID, ALKEMART_SALES_CHANNEL_ID
#
# Bootstrap commerce infrastructure (NO products/categories catalog):
#   npx medusa exec ./src/scripts/bootstrap-commerce-context.ts
# Then:
#   npx medusa exec ./src/scripts/print-commerce-context.ts
#   npx medusa exec ./src/scripts/create-publishable-key.ts   # if not done by bootstrap
#
# create-publishable-key / bootstrap link the publishable key to EXACTLY ONE
# sales channel (prefer "Alkemart Storefront"). Multiple channels break carts.
#
# Mirror the same ids into the SPA (artifacts/alkemart/.env):
#   VITE_MEDUSA_REGION_ID / VITE_MEDUSA_SALES_CHANNEL_ID / VITE_MEDUSA_PUBLISHABLE_KEY
#
# DEV FIXTURE ONLY (refused when NODE_ENV=production):
#   seed-ghana.ts / seed-ghana-shipping.ts / seed-vendors.ts
# Production catalog comes from ETL migrate-from-express, not seed.
# -----------------------------------------------------------------------------
ALKEMART_REGION_ID=
ALKEMART_SALES_CHANNEL_ID=
ALKEMART_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Paystack Ghana (Mobile Money first) — production path (P2)
# See: docs/architecture/2026-07-15-paystack-ghana-integration.md
#
# Optional in development (MoMo checkout returns 400 without secret).
# Required in production (src/lib/env.ts refuses boot without secret).
#
# Keys:
#   Staging: sk_test_… / pk_test_…
#   Production: sk_live_… / pk_live_…
#
# Webhook:
#   POST /hooks/paystack
#   HMAC-SHA512 of raw body with PAYSTACK_SECRET_KEY (header x-paystack-signature).
#   No separate PAYSTACK_WEBHOOK_SECRET — do not invent one.
#   Register this URL in the Paystack Dashboard (test vs live matching keys).
#
# When PAYSTACK_SECRET_KEY is set, medusa-config also registers the Medusa
# payment provider module (id: paystack). Live store MoMo uses ghana-checkout
# + payments-ghana intents + paystack-client (not card sessions).
# -----------------------------------------------------------------------------
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# Commerce defaults
# -----------------------------------------------------------------------------
# ISO currency code used for storefront defaults (default: ghs)
DEFAULT_CURRENCY=ghs
# ISO country code (default: gh)
DEFAULT_COUNTRY_CODE=gh
# Pending payment intent TTL in minutes (default 30, allowed 10–120)
PAYMENT_PENDING_TTL_MINUTES=30
# Platform commission in basis points (default 700 = 7.00%)
DEFAULT_COMMISSION_BPS=700
