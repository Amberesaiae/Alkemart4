{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "bun run --filter @workspace/storefront dev",
    "dev:storefront": "bun run --filter @workspace/storefront dev",
    "dev:storefront:linux": "bun run --cwd /home/amber/alkemart-storefront dev",
    "dev:backend": "bun run --cwd apps/backend dev",
    "dev:backend:fast": "bun run --cwd /home/amber/alkemart-backend dev",
    "neon:connect": "bun run scripts/src/neon-connect-backend.ts",
    "backend:sync": "bun run scripts/src/backend-sync.ts",
    "backend:migrate": "bun run scripts/src/backend-migrate.ts",
    "lab:bootstrap": "bash scripts/lab-bootstrap-marketplace.sh",
    "smoke:onboarding": "bash scripts/smoke-onboarding-quality.sh",
    "smoke:api": "bash scripts/postman/run-newman.sh",
    "smoke:ui": "bun run --cwd e2e test:smoke",
    "smoke:rbac": "bun run --cwd e2e test:rbac",
    "smoke:catalog": "bun run --cwd e2e test:catalog",
    "smoke:live": "bash scripts/live-e2e-human-flows.sh",
    "smoke:unit:api": "bun test --cwd /home/amber/alkemart-backend/packages/api src/lib/__tests__",
    "smoke:all": "bun run smoke:onboarding && bun run smoke:catalog && bun run smoke:ui && bun run smoke:rbac",
    "smoke:all:deep": "bun run smoke:unit:api && bun run smoke:live && bun run smoke:all",
    "typecheck": "bun run --filter './apps/storefront' --filter './scripts' typecheck",
    "setup": "bun install"
  },
  "private": true,
  "devDependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "typescript": "~5.9.3"
  },
  "dependencies": {},
  "workspaces": [
    "apps/storefront",
    "apps/backend",
    "packages/shared",
    "scripts"
  ],
  "packageManager": "bun@1.3.14"
}
