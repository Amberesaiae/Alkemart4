# Alkemart clean-slate backend (Mercur + Medusa)
# Copy to .env and fill secrets. Never commit .env.
# Production values → Railway dashboard (Variables tab), never in railway.toml.

# ─── Database — Neon PostgreSQL ─────────────────────────────────────────────
# Project: alkemart_marketplace | Branch: medusa-prod
# Use the POOLED host at runtime, UNPOOLED for migrations only.
# Get both from: Neon dashboard → Connection Details → Connection string
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Neon connection pooling best practices:
#   - pooled URL uses PgBouncer (transaction mode) — safe for Medusa
#   - unpooled required for: medusa db:migrate, medusa exec scripts
#   - add ?sslmode=require to both if using external clients
#   - enable "Connection pooling" in Neon dashboard → Compute settings

# ─── Redis ──────────────────────────────────────────────────────────────────
# Railway: Add Redis service → copy the REDIS_URL from its Variables tab.
# Upstash (alternative): https://upstash.com → create Redis DB → copy URL.
# Format: redis://:password@host:port  OR  rediss://... for TLS (recommended)
REDIS_URL=redis://localhost:6379

# Catalog list cache (GET /store/alkemart/catalog)
# CATALOG_CACHE_TTL_SEC=60
# CATALOG_CACHE_DISABLED=true

# ─── Auth secrets ────────────────────────────────────────────────────────────
# Production: generate with: openssl rand -base64 48
JWT_SECRET=change-me-jwt-lab-ok-32chars-min-in-prod
COOKIE_SECRET=change-me-cookie-lab-ok-32chars-prod

# ─── CORS ────────────────────────────────────────────────────────────────────
STORE_CORS=http://localhost:5175,http://localhost:8000
ADMIN_CORS=http://localhost:7000,http://localhost:9000
VENDOR_CORS=http://localhost:7001,http://localhost:9000
AUTH_CORS=http://localhost:5175,http://localhost:7000,http://localhost:7001,http://localhost:9000

# Production example:
# STORE_CORS=https://alkemart.com,https://www.alkemart.com
# VENDOR_CORS=https://alkemart-api-production.up.railway.app/seller

MERCUR_VENDOR_URL=http://localhost:9000/seller

# ─── File Storage — S3-compatible ───────────────────────────────────────────
# Lab: FILE_DRIVER=local (files stored in ./static, lost on redeploy)
# Production: FILE_DRIVER=s3 (required — railway.toml sets this automatically)
#
# Recommended providers (all S3-compatible, use same vars below):
#
#   1. Tigris (Railway-native, free tier, global CDN):
#      Railway dashboard → New Service → Tigris → copy env vars
#      S3_ENDPOINT=https://fly.storage.tigris.dev
#      S3_REGION=auto
#
#   2. Backblaze B2 (cheapest: $0.006/GB storage, $0.01/GB download):
#      b2.backblazeb2.com → create bucket → App Keys → S3-compatible API
#      S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com  (region varies)
#      S3_REGION=us-west-004
#
#   3. AWS S3:
#      S3_ENDPOINT=  (leave blank for AWS)
#      S3_REGION=us-east-1
#
FILE_DRIVER=local
FILE_BACKEND_URL=http://localhost:9000/static

S3_FILE_URL=
S3_ENDPOINT=
S3_BUCKET=alkemart-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_PREFIX=alkemart/
# S3_ACL=  # leave unset for Tigris/R2 (no ACL support); set "public-read" for AWS S3

# ─── Email notifications ─────────────────────────────────────────────────────
# Unset = log-only (safe for dev, useless in production).
# Recommended: Resend (resend.com) — free 3 000 emails/month, excellent deliverability.
EMAIL_FROM=alkemart <noreply@alkemart.com>

# Option A — Resend (recommended)
RESEND_API_KEY=

# Option B — SMTP (any provider: Postmark, Brevo, etc.)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=false

# ─── SMS — Africa's Talking (primary channel for Ghana) ─────────────────────
# Sign up: africastalking.com → create app → API key
# Ghana direct interconnect: no extra config needed; AT has GH telco agreements.
# Sandbox: set AT_SANDBOX=true for testing (numbers must be AT sandbox numbers).
#
# Sender ID (optional): register an alphanumeric name (e.g. "ALKEMART") at:
#   africastalking.com → SMS → Sender IDs → Request Sender ID
#   Without a registered sender ID, messages show the AT shortcode.
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=ALKEMART
# AT_SANDBOX=false

# ─── WhatsApp Business — Meta Cloud API ──────────────────────────────────────
# Setup: business.facebook.com → WhatsApp → Getting started
# Free tier: 1 000 business-initiated conversations/month
# Steps:
#   1. Create Meta Business account
#   2. Add WhatsApp product → get phone number ID + temporary access token
#   3. Create a System User (Settings → System Users) → generate permanent token
#   4. Create message templates (business.facebook.com → WhatsApp → Message Templates)
#      and wait for approval (~24h)
# Required templates (create these in Meta Business Manager):
#   alkemart_order_confirmed  — body: Hi {{1}}, order {{2}} for {{3}} is confirmed.
#   alkemart_order_shipped    — body: Your order {{1}} is on its way!
#   alkemart_new_order_vendor — body: {{1}}, new order {{2}} ({{3}} items). Log in to pack.
#   alkemart_seller_approved  — body: Your shop "{{1}}" is approved. Start listing now!
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_TEMPLATE_LANG=en_US

# ─── Paystack — Ghana card + MoMo ────────────────────────────────────────────
# dashboard.paystack.com → Settings → API Keys
# Use test keys locally, live keys in production only.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# ─── Search — Meilisearch ────────────────────────────────────────────────────
# Railway: New Service → Meilisearch (community template) → copy env vars
# Meilisearch Cloud (managed): cloud.meilisearch.com → free tier available
# Self-host on Railway: use the official Meilisearch Docker image (getmeili/meilisearch)
#
# After setting, reindex with:
#   bun medusa exec ./src/scripts/reindex-search.ts
#   OR POST /admin/search/reindex (authenticated)
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_API_KEY=change-me-meili-master-key
MEILISEARCH_INDEX_UID=products

# ─── Storefront ──────────────────────────────────────────────────────────────
# Used for absolute URLs in GET /store/sitemap — set to production domain
STOREFRONT_URL=http://localhost:5175

# ─── Feature flags ───────────────────────────────────────────────────────────
# ALKEMART_STRICT_PROPOSE_GATES=true
# ALKEMART_REQUIRE_CATEGORY_ON_PROPOSE=false
# ALKEMART_REPLACE_THUMBNAIL=false
# ALKEMART_MAX_IMAGE_BYTES=5242880

