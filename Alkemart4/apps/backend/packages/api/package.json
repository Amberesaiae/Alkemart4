{
  "name": "@acme/api",
  "version": "2.2.0-canary.8",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "exports": {
    "./_generated": {
      "types": "./.mercur/routes.d.ts"
    }
  },
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "medusa build && node ./scripts/bundle-dashboards.mjs",
    "seed": "medusa exec ./src/scripts/seed.ts",
    "start": "medusa start",
    "dev": "medusa develop",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit",
    "codegen": "mercurjs codegen",
    "cloud:prebuild": "mercurjs codegen"
  },
  "dependencies": {
    "@medusajs/admin-sdk": "2.17.2",
    "@medusajs/admin-shared": "2.17.2",
    "@medusajs/cli": "2.17.2",
    "@medusajs/dashboard": "2.17.2",
    "@medusajs/draft-order": "2.17.2",
    "@medusajs/framework": "2.17.2",
    "@medusajs/medusa": "2.17.2",
    "@mercurjs/cli": "2.2.0",
    "@mercurjs/core": "2.2.0",
    "@mercurjs/types": "2.2.0",
    "http-proxy-middleware": "3.0.7",
    "ioredis": "^5.11.1",
    "meilisearch": "^0.59.0",
    "sharp": "^0.34.2",
    "zod": "^4.4.3",
    "compression": "^1.8.1"
  },
  "devDependencies": {
    "@acme/admin": "*",
    "@acme/vendor": "*",
    "@alkemart/ghana-vendor": "*",
    "@medusajs/test-utils": "2.17.2",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  }
}
