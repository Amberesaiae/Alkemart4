{
  "name": "@workspace/storefront",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0 --port 5175",
    "build": "vite build --config vite.config.ts",
    "build:seo": "vite build --config vite.config.ts && node scripts/prerender-pdp.mjs",
    "prerender:pdp": "node scripts/prerender-pdp.mjs",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0 --port 5175",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "NODE_OPTIONS='--experimental-vm-modules' vitest run",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' vitest"
  },
  "dependencies": {
    "@medusajs/js-sdk": "^2.17.2",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/react": "^10.66.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.170.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "posthog-js": "^1.404.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.3.1",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/router-plugin": "^1.168.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "happy-dom": "^20.10.6",
    "jsdom": "^29.1.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.10"
  }
}
