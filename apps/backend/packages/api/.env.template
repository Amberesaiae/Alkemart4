# Alkemart clean-slate backend (Mercur + Medusa)
# Copy to .env and fill secrets. Never commit .env.

# --- Database (Neon recommended) ---
# Prefer: bun run neon:connect  (from monorepo root; uses neonctl + .neon context)
# Dedicated DB: alkemart_marketplace on branch medusa-prod — do NOT use Express neondb.
# Runtime: pooled host (-pooler). Migrations: unpooled if pooler issues.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# --- Redis (required for Medusa workers / events in real setups) ---
REDIS_URL=redis://localhost:6379

# --- Auth secrets (replace in every environment) ---
JWT_SECRET=change-me-jwt
COOKIE_SECRET=change-me-cookie

# --- CORS ---
# SPA (Alkemart Vite) default local: 5175
STORE_CORS=http://localhost:5175,http://localhost:8000
ADMIN_CORS=http://localhost:7000,http://localhost:9000
VENDOR_CORS=http://localhost:7001,http://localhost:9000
AUTH_CORS=http://localhost:5175,http://localhost:7000,http://localhost:7001,http://localhost:9000

# Vendor panel public URL (Mercur)
MERCUR_VENDOR_URL=http://localhost:9000/seller

# File uploads (local provider)
FILE_BACKEND_URL=http://localhost:9000/static

# --- Paystack (Ghana card + MoMo via Medusa payment provider) ---
# When PAYSTACK_SECRET_KEY is set, apps/backend registers pp_paystack.
# PAYSTACK_SECRET_KEY=sk_test_...
# PAYSTACK_PUBLIC_KEY=pk_test_...
# PAYSTACK_WEBHOOK_SECRET=  # optional; provider uses secret key HMAC for webhooks

# --- Search / discovery (Meilisearch) — optional; storefront falls back to product.list ---
# Local: docker compose -f docker-compose.search.yml up -d
# MEILISEARCH_HOST=http://127.0.0.1:7700
# MEILISEARCH_API_KEY=alkemart_dev_master_key_change_me
# MEILISEARCH_INDEX_UID=products
# Reindex: medusa exec ./src/scripts/reindex-search.ts
# Admin: POST /admin/search/reindex (Search sync)

# Public storefront origin for absolute URLs in GET /store/sitemap
# STOREFRONT_URL=http://localhost:5175
