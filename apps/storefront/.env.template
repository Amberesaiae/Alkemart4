# Copy to .env and fill from Mercur Admin / seed OUTPUT — never invent IDs in code.
# See docs/architecture/2026-07-16-no-hardcodes-no-magic.md

# Required
VITE_MEDUSA_BACKEND_URL=
VITE_MEDUSA_PUBLISHABLE_KEY=
VITE_MEDUSA_REGION_ID=
VITE_MEDUSA_SALES_CHANNEL_ID=

# Optional Mercur panel links (external; not SPA routes)
VITE_MERCUR_VENDOR_URL=
VITE_MERCUR_ADMIN_URL=

# Optional product analytics (PostHog Cloud) — leave empty to disable
# Create a project at https://posthog.com → Project API key
VITE_PUBLIC_POSTHOG_KEY=
# Optional override (default https://us.i.posthog.com; EU: https://eu.i.posthog.com)
VITE_PUBLIC_POSTHOG_HOST=

# Optional public site origin for canonical/OG URLs (production)
# VITE_PUBLIC_SITE_URL=https://shop.example.com

# Lab Mobile Money UI (Mode B: default off — COD is the demo path)
# VITE_FEATURE_MOMO_LAB=true

# Error tracking (optional)
VITE_SENTRY_DSN=
