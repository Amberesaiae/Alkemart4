<?xml version="1.0" encoding="UTF-8"?>
<!--
  Static route skeleton for the SPA.
  Product/store URLs should be added by a build job or backend export
  (see docs/architecture/2026-07-17-search-ops.md and SEO plan Phase 3).
  Replace base with your public origin when deploying.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url><loc>/</loc><changefreq>daily</changefreq><priority>1.0</priority></url>
  <url><loc>/browse/all</loc><changefreq>daily</changefreq><priority>0.9</priority></url>
  <url><loc>/search</loc><changefreq>weekly</changefreq><priority>0.5</priority></url>
  <url><loc>/sellers</loc><changefreq>weekly</changefreq><priority>0.7</priority></url>
  <url><loc>/sell</loc><changefreq>monthly</changefreq><priority>0.6</priority></url>
  <url><loc>/partners</loc><changefreq>monthly</changefreq><priority>0.5</priority></url>
  <url><loc>/help</loc><changefreq>monthly</changefreq><priority>0.4</priority></url>
</urlset>
