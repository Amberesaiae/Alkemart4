{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "bun run --filter @workspace/storefront dev",
    "dev:storefront": "bun run --filter @workspace/storefront dev",
    "dev:storefront:linux": "bun run --cwd /home/amber/alkemart-storefront dev",
    "dev:backend": "bun run --cwd apps/backend dev",
    "dev:backend:fast": "bun run --cwd /home/amber/alkemart-backend dev",
    "neon:connect": "bun run scripts/src/neon-connect-backend.ts",
    "backend:sync": "bun run scripts/src/backend-sync.ts",
    "backend:migrate": "bun run scripts/src/backend-migrate.ts",
    "typecheck": "bun run --filter './apps/storefront' --filter './scripts' typecheck",
    "setup": "bun install"
  },
  "private": true,
  "devDependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "typescript": "~5.9.3"
  },
  "dependencies": {},
  "workspaces": [
    "apps/storefront",
    "scripts"
  ],
  "packageManager": "bun@1.3.14"
}
