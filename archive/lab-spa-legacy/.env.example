# Alkemart storefront (Vite) — copy to `.env` and fill after Medusa seed/scripts.
# Never commit `.env` with real keys.
#
# Backend ops helpers (from alkemart-medusa/apps/backend):
#   npx medusa exec ./src/scripts/print-commerce-context.ts
#   npx medusa exec ./src/scripts/create-publishable-key.ts
# Publishable key must be linked to EXACTLY ONE sales channel.

# Ops honesty gate: off | express | medusa
# off = hide legacy SPA vendor/admin menus (default; prefer Mercur hubs)
# express = dual-home Express stubs (local only)
# medusa = transitional SPA admin RBAC pages
# VITE_OPS_BACKEND=off
# VITE_FEATURE_MEDUSA_RBAC=true

# Mercur panels (seller/admin ops — not the buyer SPA)
# VITE_MERCUR_VENDOR_URL=http://localhost:7001/seller
# VITE_MERCUR_ADMIN_URL=http://localhost:7000/dashboard

VITE_MEDUSA_BACKEND_URL=http://localhost:9000
VITE_MEDUSA_PUBLISHABLE_KEY=
VITE_MEDUSA_REGION_ID=
VITE_MEDUSA_SALES_CHANNEL_ID=
